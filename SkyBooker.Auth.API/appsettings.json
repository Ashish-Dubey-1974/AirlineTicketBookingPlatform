{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "your-super-secret-jwt-key-here-should-be-at-least-32-characters-long",
    "Issuer": "SkyBooker.Auth.API",
    "Audience": "SkyBooker.Clients",
    "ExpiryHours": "24"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=SkyBookerAuthDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Google": {
    "ClientId": "REPLACE_WITH_GOOGLE_CLIENT_ID",
    "ClientSecret": "REPLACE_WITH_GOOGLE_CLIENT_SECRET"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5000", "https://localhost:5001" ]
  }
}
